<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level [%logger{20}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling file log — useful on Oracle VM -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/traintracker.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/traintracker.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%logger{20}] %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="KafkaConsumers"  level="INFO"/>
    <logger name="CifParser"       level="INFO"/>
    <logger name="Database"        level="INFO"/>
    <logger name="Application"     level="INFO"/>

    <!-- Quiet noisy Kafka/Netty internals -->
    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="io.netty"         level="WARN"/>
    <logger name="io.ktor"          level="INFO"/>
    <logger name="Exposed"          level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
